{
  "name": "product-price-watcher-backend",
  "version": "1.0.0",
  "description": "Backend service for scraping and tracking product prices over time",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
